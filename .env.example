# Copy this file's values into Vercel → Project → Settings → Environment Variables.
# Never commit a real .env file.

# Password for the /admin dashboard (choose your own).
ADMIN_PASSWORD=

# Long random string used to sign admin login sessions (40+ random characters).
JWT_SECRET=

# These are created automatically when you add the "Upstash for Redis" integration
# (Vercel → Storage → Marketplace Database Providers) to this project — you
# normally do NOT set these by hand. Depending on the integration, they may be
# named KV_REST_API_URL/KV_REST_API_TOKEN or UPSTASH_REDIS_REST_URL/UPSTASH_REDIS_REST_TOKEN;
# this project reads either pair.
KV_REST_API_URL=
KV_REST_API_TOKEN=
