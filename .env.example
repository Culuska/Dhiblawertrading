# Copy this file's values into Vercel → Project → Settings → Environment Variables.
# Never commit a real .env file.

# Password for the /admin dashboard (choose your own).
ADMIN_PASSWORD=

# Long random string used to sign admin login sessions (40+ random characters).
JWT_SECRET=

# These are created automatically when you add the Vercel KV (or Vercel Marketplace
# "Upstash for Redis") integration to this project in the Vercel dashboard —
# you normally do NOT set these by hand.
KV_REST_API_URL=
KV_REST_API_TOKEN=
